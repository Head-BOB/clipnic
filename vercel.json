{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/brands", "destination": "/brands.html" },
    { "source": "/brand", "destination": "/brands.html" },
    { "source": "/case-studies", "destination": "/case-studies.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/docs/(.*)", "destination": "/docs.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
